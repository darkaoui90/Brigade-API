{
  "info": {
    "name": "Brigade API",
    "_postman_id": "d6d25d8d-0207-4e3f-b4c7-2b7a4e68a2b1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (sets token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{ http://127.0.0.1:8000}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{ http://127.0.0.1:8000}}/api/user"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{http://127.0.0.1:8000}}/api/logout"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.environment.set('category_id', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Entrées\"\n}"
            }
          }
        },
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/categories"
          }
        },
        {
          "name": "Show category",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/categories/{{category_id}}"
          }
        },
        {
          "name": "Update category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/categories/{{category_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Desserts\"\n}"
            }
          }
        },
        {
          "name": "Attach plats to category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/categories/{{category_id}}/plats",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plat_ids\": [{{plat_id}}]\n}"
            }
          }
        },
        {
          "name": "Delete category",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/categories/{{category_id}}"
          }
        }
      ]
    },
    {
      "name": "Plats",
      "item": [
        {
          "name": "Create plat (sets plat_id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.environment.set('plat_id', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/plats",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza\",\n  \"description\": \"Desc\",\n  \"price\": 10.5,\n  \"category_id\": {{category_id}}\n}"
            }
          }
        },
        {
          "name": "List plats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/plats"
          }
        },
        {
          "name": "Show plat",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/plats/{{plat_id}}"
          }
        },
        {
          "name": "Update plat",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/plats/{{plat_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza Updated\",\n  \"description\": null,\n  \"price\": 12,\n  \"category_id\": {{category_id}}\n}"
            }
          }
        },
        {
          "name": "Delete plat",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{}}/api/plats/{{plat_id}}"
          }
        }
      ]
    }
  ]
}

