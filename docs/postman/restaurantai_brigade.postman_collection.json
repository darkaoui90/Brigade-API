{
  "info": {
    "name": "RestaurantAI-Brigade API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\",\n  \"dietary_tags\": [\"gluten_free\"]\n}"
            }
          }
        },
        {
          "name": "Login (user) -> token_user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('token_user', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            }
          }
        },
        {
          "name": "Login (admin) -> token_admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('token_admin', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            }
          }
        },
        {
          "name": "Me (user)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/me"
          }
        },
        {
          "name": "Logout (user)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/logout"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/profile"
          }
        },
        {
          "name": "Update profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dietary_tags\": [\"gluten_free\", \"no_lactose\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Catalog (User)",
      "item": [
        {
          "name": "List categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.length) { pm.environment.set('category_id', json.data[0].id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/categories"
          }
        },
        {
          "name": "List plates",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.length) { pm.environment.set('plate_id', json.data[0].id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/plates"
          }
        },
        {
          "name": "Show plate",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/plates/{{plate_id}}"
          }
        },
        {
          "name": "Category plates",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/categories/{{category_id}}/plates"
          }
        }
      ]
    },
    {
      "name": "Recommendations",
      "item": [
        {
          "name": "Analyze plate (async)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/recommendations/analyze/{{plate_id}}"
          }
        },
        {
          "name": "List recommendations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/recommendations"
          }
        },
        {
          "name": "Recommendation for plate",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": "{{base_url}}/api/recommendations/{{plate_id}}"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": "{{base_url}}/api/admin/stats"
          }
        },
        {
          "name": "Create ingredient",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.id) { pm.environment.set('ingredient_id', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": "{{base_url}}/api/ingredients",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Ingredient\",\n  \"tags\": [\"contains_gluten\"]\n}"
            }
          }
        },
        {
          "name": "Create category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.id) { pm.environment.set('admin_category_id', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": "{{base_url}}/api/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Category\",\n  \"description\": \"Created from Postman\",\n  \"color\": \"#60A5FA\",\n  \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "Create plate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": "{{base_url}}/api/plates",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Plate\",\n  \"description\": \"Created from Postman\",\n  \"price\": 7.5,\n  \"category_id\": {{admin_category_id}},\n  \"ingredient_ids\": [{{ingredient_id}}]\n}"
            }
          }
        }
      ]
    }
  ]
}

